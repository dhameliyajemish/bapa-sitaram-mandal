{
  "name": "bapasitarm-mandal-mern",
  "version": "1.0.0",
  "description": "Mandal Management System MERN Stack",
  "main": "electron.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "desktop": "electron .",
    "electron-pack": "electron-builder build --win --dir",
    "electron-dist": "electron-builder build --win",
    "build-all": "npm run build --prefix client && npm run electron-dist"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.bapasitarammandal.app",
    "productName": "Bapa Sitaram Mandal Management",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron.js",
      "package.json",
      "server/**/*",
      "client/dist/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}